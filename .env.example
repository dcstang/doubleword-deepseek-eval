# ── Doubleword API (OpenAI-compatible) — for DeepSeek access ──────────────────
DOUBLEWORD_API_KEY=your_doubleword_api_key_here
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1

# ── Google Gemini API ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model names (override if needed) ──────────────────────────────────────────
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V4-Flash
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_PRO_MODEL=gemini-3.1-pro-preview

# ── Context window limits (tokens) ────────────────────────────────────────────
# Set DEEPSEEK_MAX_CONTEXT to your model's actual published limit
DEEPSEEK_MAX_CONTEXT=65536
# Gemini 3 Flash supports up to 1M tokens
GEMINI_MAX_CONTEXT=800000
# Target tokens for long context test (capped per-model above)
TARGET_CONTEXT_TOKENS=800000

# ── Batch / delayed mode ───────────────────────────────────────────────────────
# Doubleword delayed batch: OpenAI Batch API with completion_window="1h"
# Typically ~50% cheaper than synchronous — recommended for long context eval
USE_DOUBLEWORD_BATCH=true
# Gemini batch API (google-genai batches, falls back to concurrent if unsupported)
USE_GEMINI_BATCH=false
# How often to poll batch status (seconds)
BATCH_POLL_INTERVAL_S=30

# ── Pricing (USD per million tokens) — verify at provider pricing pages ────────
# DeepSeek-V4-Flash via Doubleword
DEEPSEEK_INPUT_PRICE=0.27
DEEPSEEK_OUTPUT_PRICE=1.10
DEEPSEEK_BATCH_DISCOUNT=0.50   # 50% off in delayed/batch mode

# Gemini 3 Flash
GEMINI_FLASH_INPUT_PRICE=0.075
GEMINI_FLASH_OUTPUT_PRICE=0.30
GEMINI_FLASH_BATCH_DISCOUNT=0.50

# Gemini 3 Pro (judge only, always synchronous)
GEMINI_PRO_INPUT_PRICE=1.25
GEMINI_PRO_OUTPUT_PRICE=5.00

# ── Pro model comparison (optional — pass --include-pro to main.py) ────────────
# Leave blank / unset to skip the 4-way comparison.
# DEEPSEEK_PRO_MODEL=deepseek-ai/DeepSeek-V4-Pro
# GEMINI_EVAL_PRO_MODEL=gemini-3.1-pro-preview

# Gemini Pro batch API for pro evaluation (usually false — Pro has a generous RPM)
# USE_GEMINI_PRO_BATCH=false

# DeepSeek-V4-Pro via Doubleword
# Batch $0.87/$1.74 · Async $1.31/$2.75 · Realtime $1.74/$3.48 per 1M (in/out)
# DEEPSEEK_PRO_INPUT_PRICE=1.74
# DEEPSEEK_PRO_OUTPUT_PRICE=3.48
# DEEPSEEK_PRO_BATCH_DISCOUNT=0.50   # 50% off in Doubleword delayed/batch mode

# Gemini 3.1 Pro Preview (as evaluatee)
# Tiered: ≤200k input tokens $1/$6, >200k input tokens $2/$9 per 1M (Flex/Batch)
# GEMINI_EVAL_PRO_INPUT_PRICE=2.00   # set to 1.00 for ≤200k-token contexts
# GEMINI_EVAL_PRO_OUTPUT_PRICE=9.00
# GEMINI_EVAL_PRO_BATCH_DISCOUNT=0.50

# ── Optional ───────────────────────────────────────────────────────────────────
# HF_TOKEN=your_hf_token    # only needed for gated HuggingFace datasets
# RESULTS_DIR=results
